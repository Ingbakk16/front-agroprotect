# AI provider for chat
# Supported values: groq, google
AI_PROVIDER=groq
AI_MODEL=llama-3.1-8b-instant

# Groq API key (recommended default for chat)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API (optional fallback if AI_PROVIDER=google)
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# GCP project used by Gemini and GCS access
GCP_PROJECT_ID=your_gcp_project_id

# Local development only: absolute path to the service account JSON.
# Recommended initial credential: reuse the dbt service account if it can read the exports bucket.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/dbt-service-account.json

# Vercel/serverless only: same service account JSON encoded as base64.
# Do not set this in local development if you already use GOOGLE_APPLICATION_CREDENTIALS.
# AGRO_GCP_SERVICE_ACCOUNT_JSON_BASE64=

# Agro data source
# Supported values: mock, gcs
AGRO_DATA_SOURCE=gcs
AGRO_FALLBACK_TO_MOCK=true

# GCS export location
AGRO_EXPORT_GCS_BUCKET=agroprotect-exports-prod
AGRO_EXPORT_GCS_PREFIX=prod/exports
AGRO_EXPORT_MANIFEST_OBJECT=export_manifest.json

# Optional cache and rollout controls
# AGRO_MANIFEST_CACHE_TTL_SEC=120
# AGRO_ALLOWED_EXPORTS=dim_location,fct_weather_daily,fct_tax_province,fct_yield_province_campaign,mart_agro_province_campaign

# Environment
NODE_ENV=development

# Vercel Configuration (auto-set by Vercel)
# VERCEL_ENV=development
# VERCEL_URL=http://localhost:3000
