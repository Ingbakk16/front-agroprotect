# Google Gemini API
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# GCP Configuration
GCP_PROJECT_ID=your_gcp_project_id

# BigQuery Configuration (optional, for direct queries)
# BIGQUERY_DATASET=agroprotect
# BIGQUERY_TABLE=risk_monitoring

# MCP Server Configuration (if using custom MCP)
# MCP_BIGQUERY_ENDPOINT=http://localhost:3001
# MCP_TIMEOUT=30000

# Environment (development, staging, production)
NODE_ENV=development

# Vercel Configuration (auto-set by Vercel)
# VERCEL_ENV=development
# VERCEL_URL=http://localhost:3000
